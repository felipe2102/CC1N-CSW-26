    {
      "id": "wM2CDffxKUC1J6bZUXb2V",
      "type": "text",
      "x": 1501,
      "y": 1491.6666666666665,
      "width": 381.45001220703125,
      "height": 250,
      "angle": 0,
      "strokeColor": "#1e1e1e",
