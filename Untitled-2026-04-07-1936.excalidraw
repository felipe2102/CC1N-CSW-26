      "seed": 638397106,
      "version": 347,
      "versionNonce": 1851426606,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1775603202218,
      "link": null,
      "locked": false,
      "text": "CREATE TABLE emprgado (\nmatricula INTEGER NOT NULL,\n...\nsalario NUMERIC(9,2) NOT NULL,\ndescontos NUMERIC(9,2) NOT NULL,\nCONSTRAINT pk_empregado\n    PRIMARY KEY (matricula),\nCONSTRAINT desconto_menor_salario\n   CHECK (descontos < salario)\n    ",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "CREATE TABLE emprgado (\nmatricula INTEGER NOT NULL,\n...\nsalario NUMERIC(9,2) NOT NULL,\ndescontos NUMERIC(9,2) NOT NULL,\nCONSTRAINT pk_empregado\n    PRIMARY KEY (matricula),\nCONSTRAINT desconto_menor_salario\n   CHECK (descontos < salario)\n    ",
